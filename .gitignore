# =============================================================================
# evo-agents - .gitignore
# 目的：保护个人信息和敏感数据，只提交代码和文档
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# 虚拟环境
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# ⚠️  运行时数据（每个 agent 实例独有，不提交）
# -----------------------------------------------------------------------------

# Agent 运行时数据目录
data/*/
!data/.gitkeep

# 搜索索引（运行时生成）
data/index/

# 锁文件
data/.locks/

# OpenClaw 运行时状态
.openclaw/
.agent-runtime/

# 每日记忆文件（运行时生成，agent 特有）
memory/????-??-??.md
memory/weekly/
memory/monthly/
memory/archive/

# 知识库 JSON（agent 学到的知识）
public/ai/
public/architecture/
public/coding/
public/data/
public/devops/
public/ml/
public/web_learning/

# 优化日志（agent 特有）
OPTIMIZATION_*.md

# bridge 同步状态
.bridge_sync.json

# -----------------------------------------------------------------------------
# ⚠️  个人配置文件（敏感 - 不包含在 Git 中）
# -----------------------------------------------------------------------------

# 配置和凭证
config.yaml
config.local.yaml
credentials.json
user_profile.json
*.secret
*.secrets

# 数据库文件（包含个人记忆和知识）
*.db
*.sqlite
*.sqlite3

# 日志文件（包含个人使用记录）
*.log
*.jsonl
logs/
log/

# 学习记录（个人数据）
memory/learning/
memory/realtime_learning_*.jsonl

# -----------------------------------------------------------------------------
# 外部配置目录（整个目录在 Git 外）
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.cache

# -----------------------------------------------------------------------------
# 测试和覆盖率
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/

# -----------------------------------------------------------------------------
# 文档构建
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# 注意事项
# -----------------------------------------------------------------------------
# 1. 提交前请运行：git status 检查是否有敏感文件
# 2. 公开模板保持在 Git 中（如 config.yaml.example）
*.lock
*.local

# Agent-specific data (整个 agents/ 目录都不提交)
agents/
!agents/.gitkeep
