# =============================================================================
# ai-baby 工作区 - Git 忽略配置
# 目的：保护个人信息和敏感数据，只提交代码和文档
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# 虚拟环境
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# ⚠️  个人配置文件（敏感 - 不包含在 Git 中）
# -----------------------------------------------------------------------------

# 配置和凭证
config.yaml
config.local.yaml
credentials.json
user_profile.json
*.secret
*.secrets

# 数据库文件（包含个人记忆和知识）
*.db
*.sqlite
*.sqlite3

# 日志文件（包含个人使用记录）
*.log
*.jsonl
logs/
log/

# 学习记录（个人数据）
memory/learning/
memory/realtime_learning_*.jsonl

# -----------------------------------------------------------------------------
# 外部配置目录（整个目录在 Git 外）
# -----------------------------------------------------------------------------
# 个人配置存储在 ~/.openclaw/workspace-ai-baby-config/
# 通过符号链接或配置路径引用

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.cache

# -----------------------------------------------------------------------------
# 测试和覆盖率
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/

# -----------------------------------------------------------------------------
# 文档构建
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# 注意事项
# -----------------------------------------------------------------------------
# 1. 提交前请运行：git status 检查是否有敏感文件
# 2. 使用 git-secrets 扫描敏感信息
# 3. 个人数据存储在 ~/.openclaw/workspace-ai-baby-config/
# 4. 公开模板保持在 Git 中（如 config.yaml.example）
