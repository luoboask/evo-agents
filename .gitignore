# =============================================================================
# evo-agents - .gitignore
# 目的：保护个人信息和敏感数据，只提交代码和文档
# =============================================================================

# -----------------------------------------------------------------------------
# Install config (安装配置，包含本地路径)
# -----------------------------------------------------------------------------
.install-config

# -----------------------------------------------------------------------------
# Agent-specific data (运行时创建的 Agent 数据)
# -----------------------------------------------------------------------------
agents/
!agents/.gitkeep

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# -----------------------------------------------------------------------------
# User Scripts (用户自定义脚本，不提交到模板)
# -----------------------------------------------------------------------------
scripts/*.py
scripts/*.sh
!scripts/core/
scripts/user/
!scripts/user/.gitkeep

# 虚拟环境
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Runtime data (运行时数据) - 本地保留，不提交
# -----------------------------------------------------------------------------
data/
!data/.gitkeep
!data/README.md
data/*/work/
agents/*/data/*/work/
memory/*.md
memory/**/*.md
memory/*.db
memory/*.pkl
memory/*.json
logs/
*.log

# -----------------------------------------------------------------------------
# Build artifacts (构建产物)
# -----------------------------------------------------------------------------
node_modules/
*.tmp

# -----------------------------------------------------------------------------
# Config with secrets
# -----------------------------------------------------------------------------
config/*.env
config/*.secret
config/*.key

# -----------------------------------------------------------------------------
# Skills - exclude agent-specific
# -----------------------------------------------------------------------------
skills/aura-*/
skills/*-browser/
skills/*-publisher/
skills/*-master/
skills/japan-*/
skills/star-*/
skills/tarot-*/
skills/danger-*/

# Skills runtime data
skills/*/learning_demo_result.json
skills/*/*.result.json

# -----------------------------------------------------------------------------
# Projects (specific to certain agents)
# -----------------------------------------------------------------------------
MediaCrawler/
baoyu-skills/
xhs-research/

# -----------------------------------------------------------------------------
# Prompts and Souls (agent-specific)
# -----------------------------------------------------------------------------
prompts/
souls/

# -----------------------------------------------------------------------------
# Public data (user-generated knowledge) - 本地保留，不提交
# -----------------------------------------------------------------------------
public/**/*.json
public/**/*.md
!public/.gitkeep
!public/README.md

# -----------------------------------------------------------------------------
# Agent Instance Files (每个 Agent 自己创建，不提交)
# -----------------------------------------------------------------------------
USER.md
SOUL.md
IDENTITY.md
MEMORY.md
HEARTBEAT.md

# OpenClaw runtime
.openclaw/

# Personal configs (should not be in template)
HEARTBEAT.md
IDENTITY.md
MEMORY.md
USER.md
SOUL.md
TOOLS.md
AGENTS.md

# Tests (development only)
tests/

# -----------------------------------------------------------------------------
# 测试产生的临时数据
# -----------------------------------------------------------------------------
*custom-skill/
child-*
test-*
workspace-*

# -----------------------------------------------------------------------------
# 记忆数据（不应该提交）
# -----------------------------------------------------------------------------
memory/*.md
memory/*.db
memory/*.jsonl
memory/working_memory_*.jsonl
memory/vector_db/

# -----------------------------------------------------------------------------
# 数据目录（不应该提交）
# -----------------------------------------------------------------------------
data/*.jsonl
data/*.db
data/agent_*.jsonl
data/intelligence_*.jsonl
data/correction_*.jsonl
data/error_*.log

# -----------------------------------------------------------------------------
# 日志文件
# -----------------------------------------------------------------------------
*.log
logs/
