# =============================================================================
# evo-agents - .gitignore
# 目的：保护个人信息和敏感数据，只提交代码和文档
# =============================================================================

# -----------------------------------------------------------------------------
# Agent-specific data (运行时创建的 Agent 数据)
# -----------------------------------------------------------------------------
agents/
!agents/.gitkeep

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# 虚拟环境
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# 日志
*.log

# 敏感信息
.env
.env.local
*.key
*.pem
secrets/

# 运行时数据
data/*/
!data/.gitkeep
data/index/
data/.locks/

# 记忆
memory/????-??-??.md
memory/weekly/
memory/monthly/
memory/archive/
memory/learning/
memory/realtime_learning_*.jsonl

# OpenClaw 运行时
.openclaw/

# 特定 Agent 的 skills (用户自己添加的)
skills/aura-*/
skills/danger-xhs-browser/
skills/japan-media-agent/
skills/pinterest-browser-publisher/
skills/star-mansion-master/
skills/tarot-master/

# 公共知识（用户自己添加的）
public/data/

# 临时文件
tmp/
temp/
*.tmp
