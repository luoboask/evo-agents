# Runtime data (exclude all agent-specific data)
memory/*.md
memory/weekly/*.md
memory/monthly/*.md
memory/archive/*.md
memory/knowledge/
memory/learning/
memory/evolution_*.jsonl
memory/*.db
memory/*.pkl
memory/*.json

# Agent-specific data
agents/*/memory/
agents/*/data/
data/*/
data/*.db
data/index/

# OpenClaw runtime
.openclaw/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# Virtual environments
venv/
env/
.venv/
.env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temp
tmp/
temp/
*.tmp

# Test artifacts
test_*.log
.coverage
htmlcov/
.pytest_cache/

# Projects (git repos cloned by user)
projects/

# Public knowledge (user-generated)
public/

# Config (may contain secrets)
config/*.local.yaml
*.env
.env.*

# Agent templates (keep templates, exclude runtime data)
agents/<agent-name>/
agents/README.md
!agents/.gitkeep
