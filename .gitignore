# =============================================================================
# Unified Memory System - .gitignore
# Purpose: Protect personal data and runtime files
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# ⚠️  Runtime Data (per-agent, do not commit)
# -----------------------------------------------------------------------------

# Agent data directories
data/*/
!data/.gitkeep

# Search indexes
data/index/

# Lock files
data/.locks/

# OpenClaw runtime
.openclaw/
.agent-runtime/

# Daily memory files (agent-specific)
memory/????-??-??.md
memory/weekly/
memory/monthly/
memory/archive/
memory/knowledge/

# Knowledge JSON (agent learned)
public/ai/
public/architecture/
public/coding/
public/data/
public/devops/
public/ml/
public/web_learning/
public/operations/
public/prompt/
public/rag/
public/security/
public/tutorial/
public/openclaw/

# Optimization logs
OPTIMIZATION_*.md

# Bridge sync state
.bridge_sync.json

# Local backups
*.local
*.bak

# -----------------------------------------------------------------------------
# ⚠️  Personal Config (sensitive - not in Git)
# -----------------------------------------------------------------------------

config.yaml
config.local.yaml
credentials.json
user_profile.json
*.secret
*.secrets

# Databases (personal memory & knowledge)
*.db
*.sqlite
*.sqlite3

# Logs (personal usage)
*.log
*.jsonl
logs/
log/

# Learning records
memory/learning/
memory/realtime_learning_*.jsonl

# -----------------------------------------------------------------------------
# External Config Directories
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Temp Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.cache

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/

# -----------------------------------------------------------------------------
# Documentation Build
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# Lock files from scripts
# -----------------------------------------------------------------------------
*.lock
