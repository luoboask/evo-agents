# =============================================================================
# evo-agents - .gitignore
# 目的：保护个人信息和敏感数据，只提交代码和文档
# =============================================================================

# -----------------------------------------------------------------------------
# Agent-specific data (运行时创建的 Agent 数据)
# -----------------------------------------------------------------------------
agents/
!agents/.gitkeep

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# 虚拟环境
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Runtime data (运行时数据) - 本地保留，不提交
# -----------------------------------------------------------------------------
data/*.json
data/**/*.json
memory/*.md
memory/**/*.md
memory/*.db
memory/*.pkl
memory/*.json
logs/
*.log

# -----------------------------------------------------------------------------
# Config with secrets
# -----------------------------------------------------------------------------
config/agents.yaml
config/*.env
config/*.secret
config/*.key

# -----------------------------------------------------------------------------
# Skills - exclude agent-specific
# -----------------------------------------------------------------------------
skills/aura-*/
skills/*-browser/
skills/*-publisher/
skills/*-master/
skills/japan-*/
skills/star-*/
skills/tarot-*/
skills/danger-*/

# -----------------------------------------------------------------------------
# Projects (specific to certain agents)
# -----------------------------------------------------------------------------
MediaCrawler/
baoyu-skills/
xhs-research/

# -----------------------------------------------------------------------------
# Prompts and Souls (agent-specific)
# -----------------------------------------------------------------------------
prompts/
souls/

# -----------------------------------------------------------------------------
# Public data (user-generated) - 本地保留，不提交
# -----------------------------------------------------------------------------
public/*/
!public/common/
!public/domain/
!public/faq/
!public/prompt/
!public/rag/
!public/security/
!public/skills/
!public/tutorial/

# -----------------------------------------------------------------------------
# Agent Instance Files (每个 Agent 自己创建，不提交)
# -----------------------------------------------------------------------------
USER.md
SOUL.md
IDENTITY.md
MEMORY.md
HEARTBEAT.md
